PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
JWT_SECRET=YOUR_JWT_SECRET
JWT_EXPIRES_IN=15m
BCRYPT_SALT_ROUNDS=12
DYNAMODB_USERS_TABLE_NAME=Users
DYNAMODB_REFRESH_TOKENS_TABLE_NAME=RefreshTokens
DYNAMODB_MEDICATIONS_TABLE_NAME=Medications
DYNAMODB_ADHERENCE_TABLE_NAME=AdherenceRecords
DYNAMODB_REMINDER_EVENTS_TABLE_NAME=ReminderEvents
DYNAMODB_CAREGIVER_RELATIONSHIPS_TABLE_NAME=CaregiverRelationships
DYNAMODB_PRESCRIPTION_UPLOADS_TABLE_NAME=PrescriptionUploads
PRESCRIPTION_STORAGE_PROVIDER=LOCAL
OCR_PROVIDER=MOCK
AI_PARSER_PROVIDER=MOCK
#OPENAI_API_KEY=YOUR_OPENAI_API_KEY
#OPENAI_MODEL=gpt-4o-mini
PRESCRIPTION_UPLOAD_DIR=uploads/prescriptions
EMAIL_PROVIDER=MOCK
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_EMAIL
SMTP_PASS=YOUR_APP_PASSWORD
EMAIL_FROM="MedTrack <your-email@example.com>"
# Optional: local development only. Leave unset when using AWS DynamoDB.
# DYNAMODB_ENDPOINT=http://localhost:8000
# Optional future providers:
# AWS_TEXTRACT_REGION=ap-south-1
# S3_PRESCRIPTION_BUCKET=YOUR_BUCKET_NAME
